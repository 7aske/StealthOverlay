<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
	<Script File="StealthOverlay.lua"/>
	<Frame name="StealthOverlay" frameStrata="BACKGROUND" hidden="true" alpha="1">
		<Scripts>
			<OnLoad>
                StealthOverlay_OnLoad(self);
			</OnLoad>
			<OnEvent>
				StealthOverlay_OnEvent(self, event, arg1, arg2);
			</OnEvent>
		</Scripts>
	</Frame>
	<Frame name="StealthOverlayFrame" parent="UIParent" frameStrata="BACKGROUND" hidden="true" alpha="0">
		<Scripts>
			<OnLoad>
				self.timer = 0;
				self.onload = false;
				self.display = false;
			</OnLoad>
			<OnUpdate>
				StealthOverlay_OnUpdate(self, elapsed);
			</OnUpdate>
		</Scripts>
		<Anchors>
			<Anchor point="TOPLEFT" relativeTo="UIParent" relativePoint="TOPLEFT" x="0" y="0"/>
			<Anchor point="BOTTOMRIGHT" relativeTo="UIParent" relativePoint="BOTTOMRIGHT" x="0" y="0"/>
		</Anchors>
		<Backdrop bgFile="Interface\AddOns\StealthOverlay\bg"></Backdrop>
	</Frame>
</Ui>
